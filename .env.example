# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored. Never commit secrets.
#
# Used by tools/gold-ai-judge.mjs, tools/gold-analyze.mjs, and the labeler's
# AI suggester. Set whichever providers you want; tools auto-select.

# OpenAI (gpt-4o-mini for vision, gpt-4o for analyst code reasoning)
OPENAI_API_KEY=sk-proj-...

# Anthropic (claude-haiku-4-5 for vision, claude-sonnet for analyst)
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides
# OPENAI_JUDGE_MODEL=gpt-4o-mini
# OPENAI_ANALYST_MODEL=gpt-4o
# CLAUDE_JUDGE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_ANALYST_MODEL=claude-sonnet-4-6
